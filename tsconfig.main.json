{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "moduleResolution": "NodeNext"
  },
  "include": ["src/main/**/*", "src/shared/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "release",
    "src/main/preload.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ]
}
