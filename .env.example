# Copy to `.env` in this folder. Electron main loads `OASIS-IDE/.env` at startup.

# OASIS ONODE base URL (auth, agents, health). The client already uses paths like /api/..., so use the site origin only:
#   https://oasisweb4.one   NOT https://oasisweb4.one/api
# If unset, uses Settings > Integrations override, else http://127.0.0.1:5003
# OASIS_API_URL=https://oasisweb4.one
# OASIS_API_URL=https://api.oasisweb4.com

# STAR WebAPI base (STARNET tools, MCP star_*). Must match how nginx exposes STAR (often /star/api on the same host as the site).
# OASIS-IDE/src/main/services/starApiUrlResolve.ts probes ${STAR_API_URL}/api/Health
# STAR_API_URL=https://oasisweb4.one/star/api

# Composer Agent: `semantic_search` (OpenAI embeddings; same base URL as chat if set)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: OASIS_IDE_EMBEDDING_MODEL=text-embedding-3-small

# Composer Agent: `web_search` tool (https://tavily.com)
# TAVILY_API_KEY=
