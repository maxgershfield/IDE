# Copy to `.env` in this folder. Electron main loads `OASIS-IDE/.env` at startup.

# -----------------------------------------------------------------------------
# Local vs remote: two ways to point the IDE at APIs
#
# A) Environment variables below (highest precedence). Use when you want the shell or CI to fix URLs.
# B) Leave OASIS_API_URL and STAR_API_URL unset, then use Settings:
#    Integrations > API Endpoint Override (ONODE), and STARNET > STAR WebAPI endpoint.
#
# If both are set, .env wins over Settings for that URL.
# -----------------------------------------------------------------------------

# OASIS ONODE base URL (auth, agents, health). The client uses paths like /api/..., so use the API host origin only:
#   https://api.oasisweb4.one   NOT https://api.oasisweb4.one/api
# If unset, uses Settings > Integrations override, else http://127.0.0.1:5003
# OASIS_API_URL=https://api.oasisweb4.one
# OASIS_API_URL=https://api.oasisweb4.com

# STAR WebAPI base: origin + optional path prefix *before* /api (e.g. https://star.oasisweb4.one).
# Do not end with /api — the IDE appends /api/Holons, /api/Health, etc.
# STAR_API_URL=https://star.oasisweb4.one

# Example: full remote profile (uncomment both; adjust hosts to match your deployment)
# OASIS_API_URL=https://api.oasisweb4.one
# STAR_API_URL=https://star.oasisweb4.one

# MCP: default is hosted Streamable HTTP (no local MCP build). For local stdio MCP:
# OASIS_MCP_TRANSPORT=stdio
# Optional override URL (default https://mcp.oasisweb4.one/mcp):
# OASIS_MCP_REMOTE_URL=https://mcp.oasisweb4.one/mcp

# Composer Agent: `semantic_search` (OpenAI embeddings; same base URL as chat if set)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: OASIS_IDE_EMBEDDING_MODEL=text-embedding-3-small

# Composer Agent: `web_search` tool (https://tavily.com)
# TAVILY_API_KEY=
