{
  "name": "oasis-ide-telegram-bridge",
  "version": "1.0.0",
  "description": "Telegram bot bridge for OASIS IDE — forwards messages from Telegram to the local IDE agent",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --watch dist/index.js",
    "dev:build": "tsc --watch"
  },
  "dependencies": {
    "grammy": "^1.32.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.3"
  }
}
