# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then paste the token here.
TELEGRAM_BOT_TOKEN=replace-with-botfather-token

# Comma-separated Telegram user IDs (numeric) that may send tasks to the IDE.
# Find your ID by messaging @userinfobot or @myidbot on Telegram.
TELEGRAM_ALLOWED_USER_IDS=123456789

# Optional: restrict further to a specific chat ID (useful for group/channel).
# Leave blank to allow any DM from an allowed user.
# TELEGRAM_ALLOWED_CHAT_ID=

# ── IDE Bridge ────────────────────────────────────────────────────────────────
# Must match OASIS_IDE_BRIDGE_SECRET in the IDE's .env
OASIS_IDE_BRIDGE_SECRET=change-me-to-a-long-random-string

# Port the OASIS IDE bridge server listens on (must match IDE setting, default 7391)
OASIS_IDE_BRIDGE_PORT=7391

# ── Optional ──────────────────────────────────────────────────────────────────
# Confirmation message sent back to Telegram when a task is queued (supports Markdown)
# CONFIRM_MESSAGE=Task received. The IDE is working on it.

# Enable courier commands such as /available, accept, picked, and delivered.
# When disabled, the bridge behaves as the regular Telegram-to-IDE task queue.
DELIVERY_BOT_ENABLED=false

# Streamable HTTP endpoint for the OASIS MCP server, e.g. run MCP with npm run start:http.
# Courier commands call holon_* tools through this endpoint so Telegram remains only an adapter.
# OASIS_MCP_HTTP_URL=http://127.0.0.1:3001/mcp

# Optional bearer token forwarded to the MCP HTTP server.
# OASIS_MCP_HTTP_TOKEN=

# Optional chat-to-courier memory restored on boot: chatId:courierHolonId,chatId:courierHolonId
# TELEGRAM_COURIER_MAP=
